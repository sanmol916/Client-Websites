<footer class="footer">
  <div class="page-width">
    <div class="footer__grid">
      {%- for block in section.blocks -%}
        <div class="footer__block" {{ block.shopify_attributes }}>
          {%- case block.type -%}
            {%- when 'brand' -%}
              {%- if block.settings.heading != blank -%}
                <div class="footer__heading" style="font-family:var(--font-heading-family);font-size:2rem;text-transform:none;letter-spacing:0;">{{ block.settings.heading }}</div>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="rte">{{ block.settings.text }}</div>
              {%- endif -%}
              {% render 'social-icons' %}

            {%- when 'menu' -%}
              {%- if block.settings.heading != blank -%}
                <div class="footer__heading">{{ block.settings.heading }}</div>
              {%- endif -%}
              <ul>
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>

            {%- when 'text' -%}
              {%- if block.settings.heading != blank -%}
                <div class="footer__heading">{{ block.settings.heading }}</div>
              {%- endif -%}
              <div class="rte">{{ block.settings.text }}</div>

            {%- when 'newsletter' -%}
              {%- if block.settings.heading != blank -%}
                <div class="footer__heading">{{ block.settings.heading }}</div>
              {%- endif -%}
              {%- if block.settings.text != blank -%}<p>{{ block.settings.text }}</p>{%- endif -%}
              {% form 'customer', class: 'newsletter-form' %}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter.email' | t }}" required aria-label="Email">
                <button type="submit" class="btn">{% render 'icon', icon: 'arrow-right' %}</button>
                {%- if form.posted_successfully? -%}
                  <p style="margin-top:1rem;">{{ 'general.newsletter.success' | t }}</p>
                {%- endif -%}
              {% endform %}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text }}</span>
      <span>{{ powered_by_link }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "default": "All rights reserved."
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand + social",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Dekor Company" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Unique, handcrafted home decor to transform your living space.</p>" }
      ]
    },
    {
      "type": "menu",
      "name": "Menu",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu", "default": "footer" }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "About" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Tell customers about your brand.</p>" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Join our newsletter" },
        { "type": "text", "id": "text", "label": "Text", "default": "Get decor inspiration and exclusive offers." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "brand" },
        { "type": "menu" },
        { "type": "text" },
        { "type": "newsletter" }
      ]
    }
  ]
}
{% endschema %}
