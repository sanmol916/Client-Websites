<div class="section">
  <div class="page-width">
    <div class="section-heading">
      <h1>{{ section.settings.heading }}</h1>
    </div>
    <div class="grid grid--{{ section.settings.columns }}">
      {%- for collection in collections -%}
        <a href="{{ collection.url }}" class="collection-card reveal">
          <div class="collection-card__media">
            {%- if collection.featured_image -%}
              <img src="{{ collection.featured_image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" width="600" height="600" loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <div class="collection-card__title">{{ collection.title }}</div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collections list",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Collections" },
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 3, "max": 5, "step": 1, "default": 4 }
  ]
}
{% endschema %}
