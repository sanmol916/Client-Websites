<div class="section">
  <div class="page-width" style="max-width:680px;">
    <div class="section-heading"><h1>{{ page.title }}</h1></div>
    {%- if page.content != blank -%}<div class="rte" style="margin-bottom:2.4rem;">{{ page.content }}</div>{%- endif -%}

    {% form 'contact' %}
      {%- if form.posted_successfully? -%}
        <p style="color:var(--color-accent);">Thanks for reaching out. We'll be in touch soon.</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p style="color:var(--color-sale);">{{ form.errors | default_errors }}</p>
      {%- endif -%}
      <div style="display:grid;gap:1.2rem;">
        <input type="text" name="contact[name]" placeholder="Name" required style="padding:1.2rem 1.6rem;border:1px solid var(--color-border);border-radius:var(--corner-radius);">
        <input type="email" name="contact[email]" placeholder="Email" required style="padding:1.2rem 1.6rem;border:1px solid var(--color-border);border-radius:var(--corner-radius);">
        <textarea name="contact[body]" placeholder="Message" rows="5" required style="padding:1.2rem 1.6rem;border:1px solid var(--color-border);border-radius:var(--corner-radius);"></textarea>
        <button type="submit" class="btn" style="justify-self:start;">Send message</button>
      </div>
    {% endform %}
  </div>
</div>

{% schema %}
{ "name": "Contact form", "settings": [] }
{% endschema %}
