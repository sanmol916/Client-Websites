<div class="section">
  <div class="page-width">
    <div class="section-heading"><h1>{{ blog.title }}</h1></div>
    <div class="grid grid--{{ section.settings.columns }}">
      {%- for article in blog.articles -%}
        <article class="card reveal">
          <a href="{{ article.url }}" class="card__media">
            {%- if article.image -%}
              <img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}" width="600" height="400" loading="lazy" style="aspect-ratio:3/2;object-fit:cover;">
            {%- else -%}
              {{ 'blog-apparel-1' | placeholder_svg_tag }}
            {%- endif -%}
          </a>
          <div class="card__info" style="text-align:left;">
            <p class="eyebrow">{{ article.published_at | date: '%b %d, %Y' }}</p>
            <h3 class="card__title" style="text-align:left;"><a href="{{ article.url }}">{{ article.title }}</a></h3>
            <p>{{ article.excerpt_or_content | strip_html | truncatewords: 24 }}</p>
            <a href="{{ article.url }}" class="link-underline">{{ 'blogs.article.read_more' | t }}</a>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Blog posts",
  "settings": [
    { "type": "range", "id": "columns", "label": "Columns (desktop)", "min": 2, "max": 4, "step": 1, "default": 3 }
  ]
}
{% endschema %}
