<div class="{% if section.settings.full_width == false %}page-width{% endif %} section" style="{% if section.settings.full_width %}padding-left:0;padding-right:0;{% endif %}">
  <div class="media-banner reveal"
    style="min-height:{{ section.settings.height }}px;{% if section.settings.image %}background-image:url('{{ section.settings.image | image_url: width: 2400 }}');{% else %}background:var(--color-border);{% endif %}">
    {%- if section.settings.overlay_opacity > 0 -%}
      <div class="slide__overlay" style="background:rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>
    {%- endif -%}
    <div class="page-width" style="width:100%;">
      <div class="media-banner__content align-{{ section.settings.alignment }}" style="{% if section.settings.alignment == 'center' %}margin:0 auto;text-align:center;{% elsif section.settings.alignment == 'right' %}margin-left:auto;text-align:right;{% endif %}color:{{ section.settings.text_color }};">
        {%- if section.settings.subheading != blank -%}<p class="eyebrow" style="color:{{ section.settings.text_color }};">{{ section.settings.subheading }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 style="color:{{ section.settings.text_color }};">{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}<div class="rte" style="color:{{ section.settings.text_color }};">{{ section.settings.text }}</div>{%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn" style="margin-top:1.6rem;">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image banner",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "checkbox", "id": "full_width", "label": "Full width", "default": true },
    { "type": "range", "id": "height", "label": "Height", "min": 300, "max": 800, "step": 20, "unit": "px", "default": 480 },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay", "min": 0, "max": 80, "step": 5, "unit": "%", "default": 30 },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Our promise" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Crafted to last a lifetime" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Top-quality raw materials, designed by the finest artisans.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Discover more" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    {
      "type": "select", "id": "alignment", "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" }
  ],
  "presets": [ { "name": "Image banner" } ]
}
{% endschema %}
