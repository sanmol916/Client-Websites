<div class="page-width" style="max-width:520px;">
  {%- if section.settings.logo != blank -%}
    <img src="{{ section.settings.logo | image_url: width: 400 }}" alt="{{ shop.name | escape }}" style="max-height:64px;width:auto;margin:0 auto 2rem;">
  {%- endif -%}
  <h1>{{ shop.name }}</h1>
  {%- if section.settings.heading != blank -%}<p class="eyebrow">{{ section.settings.heading }}</p>{%- endif -%}
  {%- if section.settings.text != blank -%}<div class="rte">{{ section.settings.text }}</div>{%- endif -%}

  {% form 'storefront_password', class: 'newsletter-form', style: 'margin:2rem auto 0;' %}
    {%- if form.errors -%}
      <p style="color:var(--color-sale);width:100%;">{{ form.errors.messages['form'] }}</p>
    {%- endif -%}
    <input type="password" name="password" placeholder="Password" required aria-label="Password">
    <button type="submit" class="btn">Enter</button>
  {% endform %}

  <p style="margin-top:2rem;font-size:1.3rem;opacity:0.7;">Are you the store owner? <a href="/admin" class="link-underline">Log in here</a></p>
</div>

{% schema %}
{
  "name": "Password",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Opening soon" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Our store is launching soon. Enter the password to preview.</p>" }
  ]
}
{% endschema %}
