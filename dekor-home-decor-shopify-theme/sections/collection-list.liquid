<div class="section">
  <div class="page-width">
    <div class="section-heading reveal">
      {%- if section.settings.subheading != blank -%}<p class="eyebrow">{{ section.settings.subheading }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    </div>

    <div class="grid grid--{{ section.settings.columns }}">
      {%- for block in section.blocks -%}
        {%- assign collection = block.settings.collection -%}
        <a href="{{ collection.url | default: '#' }}" class="collection-card reveal" {{ block.shopify_attributes }}>
          <div class="collection-card__media">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.title | default: collection.title | escape }}" width="600" height="600" loading="lazy">
            {%- elsif collection.featured_image -%}
              <img src="{{ collection.featured_image | image_url: width: 600 }}" alt="{{ collection.title | escape }}" width="600" height="600" loading="lazy">
            {%- elsif block.settings.image_file != blank -%}
              <img src="{{ block.settings.image_file | asset_url }}" alt="{{ block.settings.title | escape }}" width="600" height="600" loading="lazy">
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <div class="collection-card__title">{{ block.settings.title | default: collection.title | default: 'Category' }}</div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Collection list",
  "settings": [
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Shop by category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Explore our collections" },
    {
      "type": "range", "id": "columns", "label": "Columns (desktop)",
      "min": 3, "max": 5, "step": 1, "default": 4
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Custom image (optional)" },
        { "type": "text", "id": "image_file", "label": "Bundled demo image", "info": "e.g. category-1.jpg", "default": "category-1.jpg" },
        { "type": "text", "id": "title", "label": "Custom title (optional)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
