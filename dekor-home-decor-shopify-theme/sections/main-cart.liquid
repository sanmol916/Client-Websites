<div class="section">
  <div class="page-width" style="max-width:960px;">
    <h1 style="text-align:center;">{{ 'cart.general.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" id="cart">
        <div style="margin-top:3.2rem;">
          {%- for item in cart.items -%}
            <div class="cart-item" style="grid-template-columns:100px 1fr auto auto;align-items:center;">
              <a href="{{ item.url }}">
                {%- if item.image -%}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.title | escape }}" width="100" height="100">{%- endif -%}
              </a>
              <div>
                <a href="{{ item.url }}" style="font-weight:600;">{{ item.product.title }}</a>
                {%- unless item.variant.title contains 'Default' -%}<div style="font-size:1.3rem;opacity:0.7;">{{ item.variant.title }}</div>{%- endunless -%}
                <div class="price" style="margin-top:0.4rem;">{{ item.final_price | money }}</div>
              </div>
              <div class="quantity-selector">
                <a href="#" data-cart-change="{{ item.quantity | minus: 1 }}" data-line="{{ forloop.index }}" aria-label="Decrease">&minus;</a>
                <input type="text" value="{{ item.quantity }}" readonly aria-label="Quantity">
                <a href="#" data-cart-change="{{ item.quantity | plus: 1 }}" data-line="{{ forloop.index }}" aria-label="Increase">+</a>
              </div>
              <div style="text-align:right;min-width:100px;">
                <div class="price">{{ item.final_line_price | money }}</div>
                <a href="#" data-cart-change="0" data-line="{{ forloop.index }}" style="font-size:1.2rem;opacity:0.7;text-decoration:underline;">{{ 'cart.general.remove' | t }}</a>
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- if settings.show_cart_note -%}
          <div style="margin-top:2.4rem;">
            <label for="CartNote" style="display:block;margin-bottom:0.6rem;font-weight:600;">{{ 'cart.general.note' | t }}</label>
            <textarea id="CartNote" name="note" style="width:100%;padding:1.2rem;border:1px solid var(--color-border);border-radius:var(--corner-radius);">{{ cart.note }}</textarea>
          </div>
        {%- endif -%}

        <div style="border-top:1px solid var(--color-border);margin-top:2.4rem;padding-top:2.4rem;display:flex;flex-direction:column;align-items:flex-end;gap:1rem;">
          <div style="font-size:2rem;font-weight:600;">{{ 'cart.general.subtotal' | t }}: {{ cart.total_price | money }}</div>
          <p style="font-size:1.3rem;opacity:0.7;margin:0;">{{ 'cart.general.taxes_and_shipping_at_checkout' | t }}</p>
          <div style="display:flex;gap:1rem;">
            <button type="submit" name="update" class="btn btn--secondary">{{ 'cart.general.update' | t }}</button>
            <button type="submit" name="checkout" class="btn">{{ 'cart.general.checkout' | t }}</button>
          </div>
        </div>
      </form>
    {%- else -%}
      <div class="text-center" style="padding:4rem 0;">
        <p>{{ 'cart.general.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn">{{ 'cart.general.continue_shopping' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{ "name": "Cart", "settings": [] }
{% endschema %}
