<div class="section">
  <div class="page-width" style="max-width:780px;">
    <div class="section-heading">
      <p class="eyebrow">{{ article.published_at | date: '%b %d, %Y' }}{% if article.author %} · {{ 'blogs.article.by_author' | t: author: article.author }}{% endif %}</p>
      <h1>{{ article.title }}</h1>
    </div>
    {%- if article.image -%}
      <img src="{{ article.image | image_url: width: 1200 }}" alt="{{ article.title | escape }}" style="border-radius:var(--corner-radius);margin-bottom:2.4rem;">
    {%- endif -%}
    <div class="rte">{{ article.content }}</div>

    {%- if blog.comments_enabled? -%}
      <div style="margin-top:4rem;border-top:1px solid var(--color-border);padding-top:2.4rem;">
        <h3>{{ 'blogs.article.comments' | t: count: article.comments_count }}</h3>
        {%- for comment in article.comments -%}
          <div style="margin-bottom:1.6rem;">
            <strong>{{ comment.author }}</strong>
            <div class="rte">{{ comment.content }}</div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{ "name": "Article", "settings": [] }
{% endschema %}
