<div class="section" style="background:{{ section.settings.bg_color }};">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-heading reveal"><h2>{{ section.settings.heading }}</h2></div>
    {%- endif -%}
    <div class="features">
      {%- for block in section.blocks -%}
        <div class="feature reveal" {{ block.shopify_attributes }}>
          <div class="feature__icon">
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 120 }}" alt="{{ block.settings.title | escape }}" width="44" height="44">
            {%- else -%}
              {% render 'icon', icon: block.settings.icon %}
            {%- endif -%}
          </div>
          {%- if block.settings.title != blank -%}<h3>{{ block.settings.title }}</h3>{%- endif -%}
          {%- if block.settings.text != blank -%}<p>{{ block.settings.text }}</p>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Icon features",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Dekor Company" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "Icon",
          "options": [
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "shield", "label": "Shield (guarantee)" },
            { "value": "leaf", "label": "Leaf (quality)" },
            { "value": "gift", "label": "Gift (returns)" },
            { "value": "star", "label": "Star" }
          ],
          "default": "truck"
        },
        { "type": "image_picker", "id": "image", "label": "Custom icon (optional)" },
        { "type": "text", "id": "title", "label": "Title", "default": "Free shipping" },
        { "type": "text", "id": "text", "label": "Text", "default": "On all orders, delivered to your door." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon features",
      "blocks": [
        { "type": "feature", "settings": { "icon": "truck", "title": "Free shipping", "text": "Free delivery on every order." } },
        { "type": "feature", "settings": { "icon": "shield", "title": "Price match guarantee", "text": "Find it cheaper? We'll match it." } },
        { "type": "feature", "settings": { "icon": "leaf", "title": "Handcrafted quality", "text": "Made by the finest artisans." } },
        { "type": "feature", "settings": { "icon": "gift", "title": "Easy returns", "text": "Simple, worry-free return policy." } }
      ]
    }
  ]
}
{% endschema %}
