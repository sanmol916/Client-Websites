<div class="section">
  <div class="page-width">
    <div class="reveal" style="display:grid;gap:3.2rem;align-items:center;grid-template-columns:1fr;{% if section.settings.image %}--iwt-cols:1fr 1fr;{% endif %}"
         data-iwt>
      <div class="iwt__media" style="order:{% if section.settings.layout == 'text_first' %}2{% else %}1{% endif %};">
        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.heading | escape }}" style="border-radius:var(--corner-radius);width:100%;" loading="lazy">
        {%- elsif section.settings.image_file != blank -%}
          <img src="{{ section.settings.image_file | asset_url }}" alt="{{ section.settings.heading | escape }}" style="border-radius:var(--corner-radius);width:100%;" loading="lazy">
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>
      <div class="iwt__text" style="order:{% if section.settings.layout == 'text_first' %}1{% else %}2{% endif %};">
        {%- if section.settings.subheading != blank -%}<p class="eyebrow">{{ section.settings.subheading }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
        {%- if section.settings.text != blank -%}<div class="rte">{{ section.settings.text }}</div>{%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link }}" class="btn" style="margin-top:1.6rem;">{{ section.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} [data-iwt] { grid-template-columns: 1fr 1fr; }
  }
</style>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "image_file", "label": "Bundled demo image", "info": "e.g. vision.jpg", "default": "vision.jpg" },
    {
      "type": "select", "id": "layout", "label": "Layout",
      "options": [
        { "value": "image_first", "label": "Image first" },
        { "value": "text_first", "label": "Text first" }
      ],
      "default": "image_first"
    },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Our story" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Designed with the 7 elements of interior design" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Space, line, light, shape, color, pattern, and texture — thoughtfully combined into every piece we make.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Learn more" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [ { "name": "Image with text" } ]
}
{% endschema %}
