  {%- when 'star' -%}
    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 3 6.6 7.2.6-5.4 4.7 1.6 7L12 17.8 5.6 21l1.6-7L1.8 9.2 9 8.6z"/></svg>
  {%- when 'arrow-right' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><line x1="4" y1="12" x2="20" y2="12"/><polyline points="14 6 20 12 14 18"/></svg>
{%- endcase -%}
