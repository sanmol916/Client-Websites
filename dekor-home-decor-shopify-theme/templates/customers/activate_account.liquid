<div class="section">
  <div class="page-width" style="max-width:440px;">
    <div class="section-heading"><h1>Activate account</h1>
      <p>Create your password to activate your account.</p>
    </div>
    {% form 'activate_customer_password' %}
      {%- if form.errors -%}<p style="color:var(--color-sale);">{{ form.errors | default_errors }}</p>{%- endif -%}
      <div style="display:grid;gap:1.2rem;">
        <input type="password" name="customer[password]" placeholder="Password" required style="padding:1.2rem 1.6rem;border:1px solid var(--color-border);border-radius:var(--corner-radius);">
        <input type="password" name="customer[password_confirmation]" placeholder="Confirm password" required style="padding:1.2rem 1.6rem;border:1px solid var(--color-border);border-radius:var(--corner-radius);">
        <button type="submit" class="btn btn--full">Activate account</button>
        <button type="submit" name="decline" class="btn btn--secondary btn--full">Decline invitation</button>
      </div>
    {% endform %}
  </div>
</div>
