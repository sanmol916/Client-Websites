<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="canonical" href="{{ canonical_url }}">
    <title>{{ page_title }}</title>
    {{ content_for_header }}

    {%- liquid
      assign body_font = settings.font_body
      assign heading_font = settings.font_heading
    -%}
    {% style %}
      {{ body_font | font_face: font_display: 'swap' }}
      {{ heading_font | font_face: font_display: 'swap' }}
      :root {
        --color-background: {{ settings.color_background }};
        --color-surface: {{ settings.color_surface }};
        --color-text: {{ settings.color_text }};
        --color-heading: {{ settings.color_heading }};
        --color-accent: {{ settings.color_accent }};
        --color-accent-text: {{ settings.color_accent_text }};
        --color-border: {{ settings.color_border }};
        --color-sale: {{ settings.color_sale }};
        --font-body-family: {{ body_font.family }}, {{ body_font.fallback_families }};
        --font-body-weight: {{ body_font.weight }};
        --font-heading-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
        --font-heading-weight: {{ heading_font.weight }};
        --font-heading-scale: {{ settings.font_heading_scale | divided_by: 100.0 }};
        --font-body-scale: {{ settings.font_body_scale | divided_by: 100.0 }};
        --page-width: {{ settings.page_width }}px;
        --section-spacing: {{ settings.section_spacing }}px;
        --corner-radius: {{ settings.corner_radius }}px;
      }
    {% endstyle %}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'global.js' | asset_url }}" defer="defer"></script>
  </head>
  <body class="template-password">
    <main style="min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:4rem 1.6rem;">
      {{ content_for_layout }}
    </main>
  </body>
</html>
